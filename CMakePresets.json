 {\n      \"name\": \"clang-ci\",\n      \"displayName\": \"Clang CI Tests\",\n      \"configurePreset\": \"clang-ci\",\n      \"configuration\": \"Release\",\n      \"output\": {\n        \"outputOnFailure\": true,\n        \"verbosity\": \"default\"\n      }\n    }\n  ],\n  \"packagePresets\": [\n    {\n      \"name\": \"clang-package\",\n      \"displayName\": \"Clang Package\",\n      \"configurePreset\": \"clang\",\n      \"generators\": [\"TGZ\", \"DEB\"]\n    },\n    {\n      \"name\": \"gcc-package\",\n      \"displayName\": \"GCC Package\",\n      \"configurePreset\": \"gcc\",\n      \"generators\": [\"TGZ\", \"RPM\"]\n    }\n  ],\n  \"workflowPresets\": [\n    {\n      \"name\": \"clang-full\",\n      \"displayName\": \"Clang Complete Pipeline\",\n      \"description\": \"Full development workflow using Clang toolchain\",\n      \"steps\": [\n        {\n          \"type\": \"configure\",\n          \"name\": \"clang\"\n        },\n        {\n          \"type\": \"build\",\n          \"name\": \"clang\"\n        },\n        {\n          \"type\": \"test\",\n          \"name\": \"clang\"\n        },\n        {\n          \"type\": \"package\",\n          \"name\": \"clang-package\"\n        }\n      ]\n    },\n    {\n      \"name\": \"gcc-full\",\n      \"displayName\": \"GCC Complete Pipeline\",\n      \"description\": \"Full development workflow using GCC toolchain\",\n      \"steps\": [\n        {\n          \"type\": \"configure\",\n          \"name\": \"gcc\"\n        },\n        {\n          \"type\": \"build\",\n          \"name\": \"gcc\"\n        },\n        {\n          \"type\": \"test\",\n          \"name\": \"gcc\"\n        },\n        {\n          \"type\": \"package\",\n          \"name\": \"gcc-package\"\n        }\n      ]\n    },\n    {\n      \"name\": \"gcc-ci\",\n      \"displayName\": \"GCC CI Pipeline\",\n      \"description\": \"CI workflow using GCC toolchain: configure, build, test\",\n      \"steps\": [\n        {\n          \"type