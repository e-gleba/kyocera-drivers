{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Base Configuration",
      "description": "Base preset containing common project configurations and settings",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_COLOR_DIAGNOSTICS": "ON"
      },
      "environment": {
        "NINJA_STATUS": "[%f/%t] "
      }
    },
    {
      "name": "gcc_amd64",
      "displayName": "GCC amd64 Linux",
      "description": "GCC toolchain for Linux x86_64 with C23/C++26 and Release optimizations",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fdiagnostics-color=always"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "clang_amd64",
      "displayName": "Clang amd64 Linux",
      "description": "Clang toolchain for Linux x86_64 with C23/C++26 and Release optimizations",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic"
      },
      "environment": {
        "CC": "clang",
        "CXX": "clang++"
      }
    },
    {
      "name": "gcc_amd64_ci",
      "displayName": "GCC amd64 CI",
      "description": "CI preset: open-source driver + tests enabled",
      "inherits": "gcc_amd64",
      "cacheVariables": {
        "INSTALL_ORIGINAL_PROPRIETARY_DRIVERS": "OFF",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "clang_amd64_ci",
      "displayName": "Clang amd64 CI",
      "description": "CI preset: open-source driver + tests enabled",
      "inherits": "clang_amd64",
      "cacheVariables": {
        "INSTALL_ORIGINAL_PROPRIETARY_DRIVERS": "OFF",
        "BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc_amd64",
      "displayName": "GCC amd64 Build",
      "configurePreset": "gcc_amd64",
      "configuration": "Release"
    },
    {
      "name": "clang_amd64",
      "displayName": "Clang amd64 Build",
      "configurePreset": "clang_amd64",
      "configuration": "Release"
    },
    {
      "name": "gcc_amd64_ci",
      "displayName": "GCC amd64 CI Build",
      "configurePreset": "gcc_amd64_ci",
      "configuration": "Release"
    },
    {
      "name": "clang_amd64_ci",
      "displayName": "Clang amd64 CI Build",
      "configurePreset": "clang_amd64_ci",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "gcc_amd64",
      "displayName": "GCC amd64 Tests",
      "configurePreset": "gcc_amd64",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "clang_amd64",
      "displayName": "Clang amd64 Tests",
      "configurePreset": "clang_amd64",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "gcc_amd64_ci",
      "displayName": "GCC amd64 CI Tests",
      "configurePreset": "gcc_amd64_ci",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "clang_amd64_ci",
      "displayName": "Clang amd64 CI Tests",
      "configurePreset": "clang_amd64_ci",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    }
  ],
  "packagePresets": [
    {
      "name": "gcc_amd64_package",
      "displayName": "GCC amd64 Package",
      "configurePreset": "gcc_amd64",
      "generators": ["TGZ", "RPM"]
    },
    {
      "name": "clang_amd64_package",
      "displayName": "Clang amd64 Package",
      "configurePreset": "clang_amd64",
      "generators": ["TGZ", "DEB"]
    }
  ],
  "workflowPresets": [
    {
      "name": "gcc_amd64_full",
      "displayName": "GCC amd64 Complete Pipeline",
      "description": "Full configure → build → test → package workflow for GCC on Linux x86_64",
      "steps": [
        { "type": "configure", "name": "gcc_amd64" },
        { "type": "build", "name": "gcc_amd64" },
        { "type": "test", "name": "gcc_amd64" },
        { "type": "package", "name": "gcc_amd64_package" }
      ]
    },
    {
      "name": "clang_amd64_full",
      "displayName": "Clang amd64 Complete Pipeline",
      "description": "Full configure → build → test → package workflow for Clang on Linux x86_64",
      "steps": [
        { "type": "configure", "name": "clang_amd64" },
        { "type": "build", "name": "clang_amd64" },
        { "type": "test", "name": "clang_amd64" },
        { "type": "package", "name": "clang_amd64_package" }
      ]
    },
    {
      "name": "gcc_amd64_ci",
      "displayName": "GCC amd64 CI Workflow",
      "description": "CI workflow: configure → build → test for GCC",
      "steps": [
        { "type": "configure", "name": "gcc_amd64_ci" },
        { "type": "build", "name": "gcc_amd64_ci" },
        { "type": "test", "name": "gcc_amd64_ci" }
      ]
    },
    {
      "name": "clang_amd64_ci",
      "displayName": "Clang amd64 CI Workflow",
      "description": "CI workflow: configure → build → test for Clang",
      "steps": [
        { "type": "configure", "name": "clang_amd64_ci" },
        { "type": "build", "name": "clang_amd64_ci" },
        { "type": "test", "name": "clang_amd64_ci" }
      ]
    }
  ]
}
